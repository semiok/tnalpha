# tnalpha 环境变量示例。复制为 .env（已 gitignore）按需填。
# 说明：LLM 配置以「模型配置」页(DB)为主，下面这些只是建默认行时的初值/生产兜底。

# ── 基础 ──
# TNALPHA_SECRET_KEY=change-me-in-prod            # cookie 签名密钥，生产必改
# TNALPHA_DATABASE_URL=sqlite:///./tnalpha.db     # 生产用 postgresql://user:pw@host/db
# TNALPHA_DATA_DIR=data                           # 上传文件根目录

# ── 文本 provider：stub | openai(兼容API) | minimax-m3 | claude-cli(订阅授权) ──
# TNALPHA_TEXT_PROVIDER=stub
# 其他 API（OpenAI 兼容：OpenAI / DeepSeek / Moonshot / MiniMax / Ollama…）
# TNALPHA_OPENAI_BASE_URL=https://api.openai.com/v1
# TNALPHA_OPENAI_API_KEY=sk-...
# TNALPHA_OPENAI_MODEL=gpt-4o-mini
# MiniMax M3 示例（OpenAI-compatible）
# TNALPHA_TEXT_PROVIDER=minimax-m3
# TNALPHA_OPENAI_BASE_URL=https://api.minimax.chat/v1
# TNALPHA_OPENAI_MODEL=MiniMax-M3
# Claude 授权（本机 claude CLI）
# TNALPHA_CLAUDE_MODEL=sonnet
# TNALPHA_LLM_TIMEOUT=180

# ── 图像 provider：stub | codex(订阅授权) | minimax-m3 ──
# TNALPHA_IMAGE_PROVIDER=stub
# MiniMax 图像 API 单独配置，不复用文本 API Key。
# TNALPHA_IMAGE_BASE_URL=https://api.minimax.chat/v1
# TNALPHA_IMAGE_API_KEY=sk-...
# TNALPHA_IMAGE_PROVIDER_MODEL=image-01
# TNALPHA_CODEX_AUTH=~/.codex/auth.json
# TNALPHA_IMAGE_MODEL=gpt-image-1-mini
# TNALPHA_IMAGE_SIZE=1024x1024
# TNALPHA_IMAGE_QUALITY=low
# TNALPHA_IMAGE_FORMAT=png
# TNALPHA_IMAGE_TIMEOUT=400
